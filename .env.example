# After-Life — Environment Variable Reference
#
# Copy this file to .env and fill in real values before running locally.
# All variables with a default listed are optional.
# Variables marked REQUIRED must be set or the service will refuse to start.
#
# For Docker Compose: values here are read automatically.
# For bare-metal / staging: export these or pass them to your process manager.

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# REQUIRED. Connection string for the MongoDB server.
# Docker Compose default (service-to-service): mongodb://mongodb:27017
# Local bare-metal default:                    mongodb://localhost:27017
MONGODB_URI=mongodb://mongodb:27017

# Database name. Change to isolate staging from production data.
MONGODB_DB=afterlife

# ─── Ollama (local LLM) ───────────────────────────────────────────────────────
# URL of the Ollama server. Docker Compose runs Ollama as a service; for bare-
# metal development pointing at a local Ollama instance, use localhost:11434.
OLLAMA_HOST=http://ollama:11434

# Model to use for persona conversations. Must be pulled before starting the API.
#   docker exec afterlife-ollama ollama pull llama3.2:3b
# Alternatives: llama3.1:8b, mistral:7b, phi3:mini
OLLAMA_MODEL=llama3.2:3b

# ─── Conversation API ─────────────────────────────────────────────────────────
# Port the FastAPI server binds to inside the container.
PORT=8000

# ─── WhatsApp Sync (Baileys) ──────────────────────────────────────────────────
# Base URL that the whatsapp-sync service uses to call the conversation API.
# Docker Compose default (service-to-service): http://api:8000
# Local bare-metal default:                    http://localhost:8000
API_BASE_URL=http://api:8000

# Directory where synced contact data (messages.json, voice notes, etc.) is written.
# This path is relative to the whatsapp-sync working directory inside the container.
CONTACTS_DIR=/data/contacts

# WhatsApp JID (phone number in international format + @s.whatsapp.net) of the
# admin user who operates the After-Life bot.
# Example: 919876543210@s.whatsapp.net
# REQUIRED for the bot to know who its operator is.
ADMIN_JID=

# ─── Voice Cloning (optional) ─────────────────────────────────────────────────
# ElevenLabs API key — required only if you want cloud-based voice cloning.
# Without this, the system falls back to local Coqui XTTS-v2 synthesis.
ELEVENLABS_API_KEY=

# ─── Vector Store ─────────────────────────────────────────────────────────────
# Filesystem path for ChromaDB persistence (inside the container).
# Mapped to a Docker volume so data survives container restarts.
CHROMA_PATH=/data/chroma

# ─── LiveKit (realtime voice sessions) ───────────────────────────────────────
# WebSocket URL of the LiveKit server.
# Cloud: wss://<project>.livekit.cloud
# Self-hosted: wss://<your-livekit-host>
LIVEKIT_URL=

# API key and secret for signing participant tokens and managing rooms.
# Create these in the LiveKit Cloud console or your self-hosted server config.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Staging overrides (uncomment and set for staging deployments) ─────────────
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/afterlife?retryWrites=true
# MONGODB_DB=afterlife_staging
# OLLAMA_HOST=http://<staging-ollama-host>:11434
# API_BASE_URL=https://api.afterlife.staging.example.com
