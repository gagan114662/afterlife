# After-Life — Environment Variable Reference
#
# Copy this file to .env and fill in real values before running.
# Variables marked REQUIRED must be set or the service will refuse to start.
# Variables with a default listed are optional.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env — set at minimum: ANTHROPIC_API_KEY, ELEVENLABS_API_KEY,
#   #             OPENAI_API_KEY, PINECONE_API_KEY, ADMIN_JID
#   docker compose up

# ─── Anthropic (Claude LLM) ───────────────────────────────────────────────────
# REQUIRED. Used by the conversation API (persona replies) and personality service
# (profile extraction + living biography generation).
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ─── ElevenLabs (Voice Cloning + TTS) ────────────────────────────────────────
# REQUIRED for voice cloning. Without this, voice synthesis is disabled.
# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ─── OpenAI (Whisper speech-to-text) ─────────────────────────────────────────
# REQUIRED for voice-note transcription in the WhatsApp bot.
# Used by the whatsapp-sync service to transcribe incoming voice notes.
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=

# ─── Pinecone (Semantic Memory Search) ───────────────────────────────────────
# REQUIRED. Used to store and query contact memory embeddings.
# Get your key at: https://app.pinecone.io/
PINECONE_API_KEY=

# Pinecone index name. Created automatically on first run if it doesn't exist.
PINECONE_INDEX=afterlife-memories

# Optional: Override the Pinecone host (for local dev with pinecone-local emulator).
# Leave empty to use Pinecone cloud.
# Local emulator: docker compose --profile local-pinecone up
#   then set: PINECONE_HOST=http://localhost:5081
PINECONE_HOST=

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# REQUIRED. Connection string for the MongoDB server.
# Docker Compose default (service-to-service): mongodb://mongodb:27017
# Local bare-metal default:                    mongodb://localhost:27017
# Atlas (production):                          mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_URI=mongodb://mongodb:27017

# Database name. Change to isolate staging/test data from production.
MONGODB_DB_NAME=afterlife

# ─── Conversation API ─────────────────────────────────────────────────────────
# Port the FastAPI server binds to inside the container.
PORT=8000

# ─── WhatsApp Sync (Baileys) ──────────────────────────────────────────────────
# Base URL that the whatsapp-sync service uses to call the conversation API.
# Docker Compose default (service-to-service): http://api:8000
# Local bare-metal default:                    http://localhost:8000
API_BASE_URL=http://api:8000

# Directory where synced contact data (messages.json, voice notes, etc.) is written.
# Mapped to a Docker volume shared between whatsapp-sync, voice-cloner, and personality.
CONTACTS_DIR=/data/contacts

# WhatsApp JID (phone number in international format + @s.whatsapp.net) of the
# admin user who operates the After-Life bot.
# Example: 919876543210@s.whatsapp.net
# REQUIRED for the bot to know who its operator is.
ADMIN_JID=

# ─── LiveKit (realtime voice sessions) ───────────────────────────────────────
# WebSocket URL of the LiveKit server.
# Cloud: wss://<project>.livekit.cloud
# Self-hosted: wss://<your-livekit-host>
LIVEKIT_URL=

# API key and secret for signing participant tokens and managing rooms.
# Create these in the LiveKit Cloud console or your self-hosted server config.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Staging overrides (uncomment and set for staging deployments) ─────────────
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/afterlife?retryWrites=true
# MONGODB_DB_NAME=afterlife_staging
# API_BASE_URL=https://api.afterlife.staging.example.com
